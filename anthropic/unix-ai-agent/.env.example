# =============================================================================
# Unix AI Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for the provider(s) you use.
#   cp .env.example .env
#
# Never commit your .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic (required when using --provider anthropic)
# Get your key at: https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Gemini (required when using --provider gemini)
# Either GEMINI_API_KEY or GOOGLE_API_KEY is accepted — only one is needed.
# Get your key at: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIza...
# GOOGLE_API_KEY=AIza...   # Alternative name — use one or the other, not both

# -----------------------------------------------------------------------------
# Optional / Debug
# -----------------------------------------------------------------------------
# Set to any non-empty value to enable verbose error stack traces
# DEBUG=true
